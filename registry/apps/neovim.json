    },
    {
      "platform": "macos",
      "arch": "aarch64",
      "kind": "tar.gz",
      "match": "nvim-macos-arm64\\.tar\\.gz$",
      "binary_name": "nvim"
    },
    {
      "platform": "windows",
      "arch": "x86_64",
